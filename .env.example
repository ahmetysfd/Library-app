# ══════════════════════════════════════════════════════════════
# SHELF — Environment Variables
# Copy this file to .env and fill in your credentials
# ══════════════════════════════════════════════════════════════

# ── Supabase (required) ──────────────────────────────────────
# Create a free project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Auth ─────────────────────────────────────────────────────
# Generate a random string: openssl rand -hex 32
JWT_SECRET=your-random-secret-at-least-32-characters-long

# ── Google OAuth (optional) ──────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── TMDB — Films & TV (optional) ─────────────────────────────
# Free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# ── IGDB — Games (optional) ──────────────────────────────────
# Register at https://dev.twitch.tv/console → create app
IGDB_CLIENT_ID=your-twitch-client-id
IGDB_ACCESS_TOKEN=your-twitch-access-token

# ── Last.fm — Album Browse (recommended) ────────────────────
# Free: https://www.last.fm/api/account/create
# Returns albums sorted by REAL listener count (popularity)
LASTFM_API_KEY=your-lastfm-api-key

# ── Spotify — Artist Browse (recommended) ───────────────────
# Free: https://developer.spotify.com/dashboard → create app
# Uses Client Credentials (no user login, no quota issues)
# Needed for Top Artists feature (followers, popularity, photos)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ── Server ───────────────────────────────────────────────────
PORT=3001
